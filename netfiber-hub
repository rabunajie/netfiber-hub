function fmtDL(d,done){if(!d)return'—';const diff=dlDiff(d);if(done)return fmtDate(d);if(diff<0)return`<span class="dl ov">${Math.abs(diff)}d overdue</span>`;if(diff===0)return`<span class="dl tod">Today</span>`;if(diff===1)return`<span class="dl">Tomorrow</span>`;return`<span class="dl">${fmtDate(d)}</span>`;}

async function renderTasks(){
  const search=(document.getElementById('task-search').value||'').toLowerCase();
  const filter=document.getElementById('task-filter').value;
  const {data:rows=[]}=await sb.from('tasks').select('*,creator:created_by(full_name),assignee:assigned_to(full_name)').order('created_at',{ascending:false});
  let visible=[...rows];
  if(filter==='pending') visible=visible.filter(t=>!t.done);
  if(filter==='done') visible=visible.filter(t=>t.done);
  if(filter==='high') visible=visible.filter(t=>t.priority==='high'&&!t.done);
  if(search) visible=visible.filter(t=>t.name.toLowerCase().includes(search));
  visible.sort((a,b)=>{if(a.done!==b.done)return a.done?1:-1;const po={high:0,medium:1,low:2};if(po[a.priority]!==po[b.priority])return(po[a.priority]||2)-(po[b.priority]||2);if(a.deadline&&b.deadline)return new Date(a.deadline)-new Date(b.deadline);if(a.deadline)return -1;if(b.deadline)return 1;return 0;});
  const total=rows.length,done=rows.filter(t=>t.done).length,pending=rows.filter(t=>!t.done).length,high=rows.filter(t=>t.priority==='high'&&!t.done).length;
  document.getElementById('task-summary').innerHTML=`
    <div class="metric"><div class="metric-v">${total}</div><div class="metric-l">Total</div></div>
    <div class="metric"><div class="metric-v" style="color:#1D9E75">${done}</div><div class="metric-l">Done</div></div>
    <div class="metric"><div class="metric-v" style="color:#185FA5">${pending}</div><div class="metric-l">Pending</div></div>
    <div class="metric"><div class="metric-v" style="color:#E24B4A">${high}</div><div class="metric-l">High priority</div></div>
  `;
  const todayTasks=rows.filter(t=>!t.done&&t.deadline===todayStr);
  document.getElementById('today-section').innerHTML=todayTasks.length?`
    <div class="today-header"><span class="dot"></span>Due today — ${todayTasks.length} task${todayTasks.length>1?'s':''}</div>
    <div style="background:#fff;border:1px solid #f09595;border-radius:10px;overflow:hidden;margin-bottom:12px">
      ${todayTasks.map(t=>`<div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:0.5px solid #f2f2f2">
        <div class="chk ${t.done?'on':''}" onclick="toggleTask('${t.id}',${t.done})"></div>
        <span style="font-size:13px;font-weight:500">${t.name}</span>
        <span class="badge high" style="margin-left:auto">Today</span>
      </div>`).join('')}
    </div>`:'';
  document.getElementById('task-list-body').innerHTML=visible.map(t=>`
    <div class="task-row ${t.done?'done-row':''}">
      <div class="chk ${t.done?'on':''}" onclick="toggleTask('${t.id}',${t.done})"></div>
      <div class="tname">${t.name}</div>
      <div><span class="badge ${t.priority==='high'?'high':t.priority==='medium'?'medium':'low'}">${t.priority||'medium'}</span></div>
      <div>${fmtDL(t.deadline,t.done)}</div>
      <div class="by-cell">${t.assignee?.full_name||t.creator?.full_name||'—'}</div>
      <div><span class="status-badge ${t.done?'s-won':'s-submitted'}">${t.done?'Done':'Pending'}</span></div>
      <div><button class="btn-danger" onclick="deleteTask('${t.id}','${t.name.replace(/'/g,'`')}')">×</button></div>
    </div>
  `).join('')||'<div style="text-align:center;padding:2rem;color:#aaa;font-size:13px">No tasks found.</div>';
}

