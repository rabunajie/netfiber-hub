// HELPERS
function fmt$(n){return '$'+Number(n||0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0});}
function fmtDate(d){if(!d)return'—';const dt=new Date(d+'T00:00:00');return dt.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'});}
function dlDiff(d){if(!d)return 999;return Math.round((new Date(d+'T00:00:00')-today)/86400000);}
function statusBadge(s){const m={'Submitted':'s-submitted','Won':'s-won','WON':'s-won','Lost':'s-lost','LOST':'s-lost','Replied':'s-replied','Did Not replay':'s-did-not'};return`<span class="status-badge ${m[s]||'s-submitted'}">${s||'Submitted'}</span>`;}
function initials(name){if(!name)return'?';return name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);}
function showPage(p){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('on'));
  document.querySelectorAll('.nav-tab').forEach(x=>x.classList.remove('on'));
  document.getElementById('page-'+p).classList.add('on');
  const labels={'bids':'Sales','gc':'GC','retail':'Retail','tasks':'To-Do','log':'Activity'};
  document.querySelectorAll('.nav-tab').forEach(x=>{if(x.textContent.includes(labels[p]))x.classList.add('on');});
  if(p==='bids')renderBids();
  if(p==='gc')renderGC();
  if(p==='retail')renderRetail();
  if(p==='tasks')renderTasks();
  if(p==='log')renderLog();
}
function closeModal(id){document.getElementById(id).classList.remove('open');}
