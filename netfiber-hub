<index.html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NetFiber Hub</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f0f4f8;color:#1a1a1a;min-height:100vh}
/* AUTH */
.auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1B5E9B 0%,#0C447C 100%)}
.auth-card{background:#fff;border-radius:16px;padding:2.5rem;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.15)}
.auth-logo{text-align:center;margin-bottom:2rem}
.auth-logo h1{font-size:24px;font-weight:700;color:#1B5E9B}
.auth-logo p{font-size:13px;color:#888;margin-top:4px}
.auth-tab{display:flex;gap:0;margin-bottom:1.5rem;border:1px solid #e8e8e8;border-radius:8px;overflow:hidden}
.auth-tab-btn{flex:1;padding:8px;border:none;background:#f9f9f9;font-size:13px;font-weight:500;cursor:pointer;color:#666;transition:all 0.15s}
.auth-tab-btn.on{background:#1B5E9B;color:#fff}
.form-field{margin-bottom:14px}
.form-field label{display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:5px}
.form-field input{width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:8px;font-size:14px;outline:none;transition:border 0.15s}
.form-field input:focus{border-color:#1B5E9B}
.auth-btn{width:100%;padding:11px;border:none;border-radius:8px;background:#1B5E9B;color:#fff;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.15s;margin-top:4px}
.auth-btn:hover{background:#0C447C}
.auth-err{background:#fcebeb;color:#a32d2d;border:1px solid #f09595;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:12px;display:none}
/* APP */
.app{display:none}
.topbar{background:#1B5E9B;color:#fff;padding:0 1.25rem;display:flex;align-items:center;height:52px;gap:0}
.logo{font-size:16px;font-weight:700;margin-right:1.5rem;white-space:nowrap}
.nav-tabs{display:flex;height:100%;flex:1}
.nav-tab{padding:0 16px;cursor:pointer;font-size:13px;font-weight:500;display:flex;align-items:center;border-bottom:3px solid transparent;color:rgba(255,255,255,0.75);transition:all 0.15s;white-space:nowrap}
.nav-tab:hover{color:#fff;background:rgba(255,255,255,0.1)}
.nav-tab.on{color:#fff;border-bottom-color:#fff}
.user-area{display:flex;align-items:center;gap:10px;margin-left:auto}
.user-badge{background:rgba(255,255,255,0.2);border-radius:20px;padding:4px 12px;font-size:12px;font-weight:500}
.logout-btn{padding:5px 12px;border-radius:6px;border:1px solid rgba(255,255,255,0.4);background:transparent;color:#fff;font-size:12px;cursor:pointer}
.logout-btn:hover{background:rgba(255,255,255,0.15)}
.page{display:none;padding:1.25rem}
.page.on{display:block}
/* COMPONENTS */
.summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:1.25rem}
.metric{background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #e8e8e8}
.metric-v{font-size:22px;font-weight:700}
.metric-l{font-size:11px;color:#888;margin-top:3px}
.toolbar{display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap;align-items:center}
.toolbar input,.toolbar select{padding:7px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px;outline:none;background:#fff}
.toolbar input:focus,.toolbar select:focus{border-color:#1B5E9B}
.btn-primary{padding:7px 16px;border-radius:8px;border:none;background:#1B5E9B;color:#fff;font-size:13px;font-weight:600;cursor:pointer}
.btn-primary:hover{background:#0C447C}
.btn-sm{padding:4px 10px;border-radius:6px;border:1px solid #ddd;background:#fff;font-size:12px;cursor:pointer;color:#555}
.btn-sm:hover{background:#f0f0f0}
.btn-danger{padding:4px 10px;border-radius:6px;border:1px solid #f09595;background:#fcebeb;font-size:12px;cursor:pointer;color:#a32d2d}
.btn-danger:hover{background:#f7c1c1}
table{width:100%;border-collapse:collapse;background:#fff;border-radius:10px;overflow:hidden;border:1px solid #e8e8e8;font-size:13px}
th{background:#f9f9f9;border-bottom:1px solid #eee;padding:9px 12px;text-align:left;font-weight:600;font-size:11px;color:#666;text-transform:uppercase;letter-spacing:0.4px;white-space:nowrap}
td{padding:9px 12px;border-bottom:0.5px solid #f2f2f2;vertical-align:top}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafcff}
.note-cell{font-size:11px;color:#888;white-space:pre-wrap;word-break:break-word;max-width:250px;line-height:1.5}
.by-cell{font-size:11px;color:#1B5E9B;font-weight:500;white-space:nowrap}
.status-badge{font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;white-space:nowrap;display:inline-block}
.s-submitted{background:#E6F1FB;color:#0C447C}
.s-won,.s-yes{background:#EAF3DE;color:#27500A}
.s-lost{background:#FCEBEB;color:#A32D2D}
.s-replied{background:#FAEEDA;color:#633806}
.s-did-not,.s-no{background:#F1EFE8;color:#5F5E5A}
.pri-1{background:#FCEBEB;color:#A32D2D;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;display:inline-block}
.pri-2{background:#FAEEDA;color:#633806;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;display:inline-block}
.pri-3{background:#EAF3DE;color:#27500A;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;display:inline-block}
/* TASKS */
.task-list{background:#fff;border-radius:10px;border:1px solid #e8e8e8;overflow:hidden}
.task-hdr{display:grid;grid-template-columns:36px 1fr 90px 110px 120px 90px 60px;gap:8px;padding:8px 14px;background:#f9f9f9;border-bottom:1px solid #eee;font-size:11px;font-weight:600;color:#666;text-transform:uppercase;letter-spacing:0.4px}
.task-row{display:grid;grid-template-columns:36px 1fr 90px 110px 120px 90px 60px;gap:8px;align-items:center;padding:10px 14px;border-bottom:0.5px solid #f2f2f2}
.task-row:hover{background:#fafcff}
.task-row:last-child{border-bottom:none}
.task-row.done-row{opacity:0.5}
.task-row.done-row .tname{text-decoration:line-through}
.chk{width:22px;height:22px;border-radius:5px;border:1.5px solid #ccc;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.15s;flex-shrink:0}
.chk:hover{border-color:#1B5E9B}
.chk.on{background:#1D9E75;border-color:#1D9E75}
.chk.on::after{content:'';width:5px;height:9px;border:2px solid #fff;border-top:none;border-left:none;transform:rotate(45deg) translate(-1px,-1px);display:block}
.badge{font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;display:inline-block}
.high{background:#FCEBEB;color:#A32D2D}
.medium{background:#FAEEDA;color:#633806}
.low{background:#EAF3DE;color:#27500A}
.none-p{background:#f0f0f0;color:#888}
.dl{font-size:12px;color:#666}
.dl.ov{color:#E24B4A;font-weight:600}
.dl.tod{color:#BA7517;font-weight:600}
.today-section{margin-bottom:1.25rem}
.today-header{font-size:13px;font-weight:700;color:#A32D2D;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.dot{width:8px;height:8px;border-radius:50%;background:#E24B4A;display:inline-block}
/* ACTIVITY LOG */
.log-item{display:flex;gap:12px;padding:10px 14px;border-bottom:0.5px solid #f2f2f2;align-items:flex-start}
.log-item:last-child{border-bottom:none}
.log-avatar{width:32px;height:32px;border-radius:50%;background:#E6F1FB;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#1B5E9B;flex-shrink:0}
.log-text{flex:1;font-size:13px}
.log-text strong{color:#1B5E9B}
.log-time{font-size:11px;color:#aaa;margin-top:2px}
/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:200;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:14px;padding:1.5rem;width:92%;max-width:620px;max-height:88vh;overflow-y:auto}
.modal h3{font-size:16px;font-weight:600;margin-bottom:1rem;color:#1B5E9B}
.form-row{margin-bottom:12px}
.form-row label{display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px}
.form-row input,.form-row select,.form-row textarea{width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px;outline:none;font-family:inherit}
.form-row input:focus,.form-row select:focus,.form-row textarea:focus{border-color:#1B5E9B}
.form-row textarea{height:80px;resize:vertical}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;padding-top:1rem;border-top:1px solid #eee}
.loading{text-align:center;padding:2rem;color:#aaa;font-size:13px}
.spinner{display:inline-block;width:20px;height:20px;border:2px solid #ddd;border-top-color:#1B5E9B;border-radius:50%;animation:spin 0.8s linear infinite;margin-right:8px;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>

<!-- AUTH PAGE -->
<div id="auth-page" class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>NetFiber Hub</h1>
      <p>Business Management Portal</p>
    </div>
    <div class="auth-tab">
      <button class="auth-tab-btn on" onclick="switchAuth('login')">Sign In</button>
      <button class="auth-tab-btn" onclick="switchAuth('signup')">Sign Up</button>
    </div>
    <div class="auth-err" id="auth-err"></div>
    <div id="login-form">
      <div class="form-field"><label>Email</label><input type="email" id="login-email" placeholder="your@email.com"></div>
      <div class="form-field"><label>Password</label><input type="password" id="login-pass" placeholder="Password" onkeydown="if(event.key==='Enter')doLogin()"></div>
      <button class="auth-btn" onclick="doLogin()">Sign In</button>
    </div>
    <div id="signup-form" style="display:none">
      <div class="form-field"><label>Full Name</label><input type="text" id="signup-name" placeholder="Ramadan Abunajie"></div>
      <div class="form-field"><label>Email</label><input type="email" id="signup-email" placeholder="your@email.com"></div>
      <div class="form-field"><label>Password</label><input type="password" id="signup-pass" placeholder="Min 6 characters"></div>
      <button class="auth-btn" onclick="doSignup()">Create Account</button>
    </div>
  </div>
</div>

<!-- APP -->
<div class="app" id="app">
  <div class="topbar">
    <div class="logo">NetFiber Hub</div>
    <div class="nav-tabs">
      <div class="nav-tab on" onclick="showPage('bids')">Sales Tracker</div>
      <div class="nav-tab" onclick="showPage('gc')">GC Contacts</div>
      <div class="nav-tab" onclick="showPage('retail')">Retail Contacts</div>
      <div class="nav-tab" onclick="showPage('tasks')">To-Do</div>
      <div class="nav-tab" onclick="showPage('log')">Activity Log</div>
    </div>
    <div class="user-area">
      <span class="user-badge" id="user-badge">...</span>
      <button class="logout-btn" onclick="doLogout()">Sign out</button>
    </div>
  </div>

  <!-- BIDS -->
  <div class="page on" id="page-bids">
    <div class="summary-grid" id="bid-summary"></div>
    <div class="toolbar">
      <input type="text" id="bid-search" placeholder="Search project, GC, ref..." oninput="renderBids()" style="flex:1;min-width:180px">
      <select id="bid-filter" onchange="renderBids()">
        <option value="">All statuses</option>
        <option>Submitted</option><option>Won</option><option>Lost</option><option>Replied</option><option>Did Not replay</option>
      </select>
      <button class="btn-primary" onclick="openBidModal()">+ New Bid</button>
    </div>
    <div style="overflow-x:auto">
      <table><thead><tr>
        <th>Ref #</th><th>Project</th><th>GC / Client</th><th>POC</th><th>Status</th>
        <th>Price</th><th>Profit</th><th>Last Ping</th><th>Notes</th><th>By</th><th></th>
      </tr></thead><tbody id="bid-body"><tr><td colspan="11" class="loading"><span class="spinner"></span>Loading...</td></tr></tbody></table>
    </div>
  </div>

  <!-- GC -->
  <div class="page" id="page-gc">
    <div class="toolbar">
      <input type="text" id="gc-search" placeholder="Search company, contact..." oninput="renderGC()" style="flex:1;min-width:180px">
      <select id="gc-filter" onchange="renderGC()"><option value="">All</option><option value="Yes">Replied</option><option value="No">No reply</option></select>
      <button class="btn-primary" onclick="openGCModal()">+ New GC</button>
    </div>
    <div style="overflow-x:auto">
      <table><thead><tr><th>Company</th><th>Contact</th><th>Email</th><th>Phone</th><th>City</th><th>Priority</th><th>Replied</th><th>Notes</th><th>By</th><th></th></tr></thead>
      <tbody id="gc-body"><tr><td colspan="10" class="loading"><span class="spinner"></span>Loading...</td></tr></tbody></table>
    </div>
  </div>

  <!-- RETAIL -->
  <div class="page" id="page-retail">
    <div class="toolbar">
      <input type="text" id="ret-search" placeholder="Search company, contact..." oninput="renderRetail()" style="flex:1">
      <button class="btn-primary" onclick="openRetailModal()">+ New Contact</button>
    </div>
    <div style="overflow-x:auto">
      <table><thead><tr><th>Company</th><th>Contact</th><th>Role</th><th>Email</th><th>Phone</th><th>Replied</th><th>Notes</th><th>By</th><th></th></tr></thead>
      <tbody id="ret-body"><tr><td colspan="9" class="loading"><span class="spinner"></span>Loading...</td></tr></tbody></table>
    </div>
  </div>

  <!-- TASKS -->
  <div class="page" id="page-tasks">
    <div class="summary-grid" id="task-summary"></div>
    <div class="today-section" id="today-section"></div>
    <div class="toolbar">
      <input type="text" id="task-search" placeholder="Search tasks..." oninput="renderTasks()" style="flex:1;min-width:180px">
      <select id="task-filter" onchange="renderTasks()">
        <option value="all">All tasks</option><option value="pending">Pending</option>
        <option value="done">Done</option><option value="high">High priority</option>
      </select>
    </div>
    <div style="background:#fff;border-radius:10px;border:1px solid #e8e8e8;padding:14px;margin-bottom:1rem">
      <div style="font-size:13px;font-weight:600;color:#555;margin-bottom:10px">Add new task</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <input type="text" id="new-task" placeholder="Task description..." onkeydown="if(event.key==='Enter')addTask()" style="flex:1;min-width:200px;padding:8px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px;outline:none">
        <select id="new-pri" style="padding:8px 10px;border:1px solid #ddd;border-radius:8px;font-size:13px;outline:none">
          <option value="high">High</option><option value="medium" selected>Medium</option><option value="low">Low</option>
        </select>
        <input type="date" id="new-date" style="padding:8px 10px;border:1px solid #ddd;border-radius:8px;font-size:13px;outline:none">
        <button class="btn-primary" onclick="addTask()">+ Add</button>
      </div>
    </div>
    <div class="task-list">
      <div class="task-hdr"><span></span><span>Task</span><span>Priority</span><span>Deadline</span><span>Assigned to</span><span>Status</span><span></span></div>
      <div id="task-list-body"><div class="loading"><span class="spinner"></span>Loading...</div></div>
    </div>
  </div>

  <!-- ACTIVITY LOG -->
  <div class="page" id="page-log">
    <div style="background:#fff;border-radius:10px;border:1px solid #e8e8e8;overflow:hidden">
      <div style="padding:12px 16px;border-bottom:1px solid #eee;font-size:13px;font-weight:600;color:#555">Recent activity</div>
      <div id="log-body"><div class="loading"><span class="spinner"></span>Loading...</div></div>
    </div>
  </div>
</div>

<!-- MODALS -->
<div class="modal-bg" id="bid-modal">
  <div class="modal">
    <h3 id="bid-modal-title">New Bid</h3>
    <div class="form-grid">
      <div class="form-row"><label>Ref #</label><input id="bm-ref" placeholder="GC26-22-xxx"></div>
      <div class="form-row"><label>Source</label><select id="bm-source"><option>PlanHub</option><option>ConstructConnect</option><option>Buildingconnect</option><option>Reach out</option><option>Other</option></select></div>
      <div class="form-row"><label>Project Name</label><input id="bm-project"></div>
      <div class="form-row"><label>Status</label><select id="bm-status"><option>Submitted</option><option>Won</option><option>Lost</option><option>Replied</option><option>Did Not replay</option></select></div>
      <div class="form-row"><label>GC / Client</label><input id="bm-gc"></div>
      <div class="form-row"><label>POC Name</label><input id="bm-poc"></div>
      <div class="form-row"><label>Email</label><input id="bm-email"></div>
      <div class="form-row"><label>Phone</label><input id="bm-phone"></div>
      <div class="form-row"><label>Price ($)</label><input id="bm-price" type="number" step="0.01" value="0"></div>
      <div class="form-row"><label>Cost ($)</label><input id="bm-cost" type="number" step="0.01" value="0"></div>
      <div class="form-row"><label>Due Date</label><input id="bm-due" type="date"></div>
      <div class="form-row"><label>Last Follow-up</label><input id="bm-ping" type="date"></div>
    </div>
    <div class="form-row"><label>Notes</label><textarea id="bm-notes"></textarea></div>
    <div class="modal-footer">
      <button class="btn-sm" onclick="closeModal('bid-modal')">Cancel</button>
      <button class="btn-primary" onclick="saveBid()">Save</button>
    </div>
  </div>
</div>

<div class="modal-bg" id="gc-modal">
  <div class="modal">
    <h3 id="gc-modal-title">GC Contact</h3>
    <div class="form-grid">
      <div class="form-row"><label>Company Name</label><input id="gm-company"></div>
      <div class="form-row"><label>Contact Name</label><input id="gm-contact"></div>
      <div class="form-row"><label>Email</label><input id="gm-email"></div>
      <div class="form-row"><label>Phone</label><input id="gm-phone"></div>
      <div class="form-row"><label>City / State</label><input id="gm-city"></div>
      <div class="form-row"><label>Priority</label><select id="gm-priority"><option>1st</option><option>2nd</option><option>3rd</option><option>Do not call</option></select></div>
      <div class="form-row"><label>Replied</label><select id="gm-replied"><option>No</option><option>Yes</option></select></div>
      <div class="form-row"><label>First Email Date</label><input id="gm-fdate" type="date"></div>
    </div>
    <div class="form-row"><label>Notes</label><textarea id="gm-notes"></textarea></div>
    <div class="modal-footer">
      <button class="btn-sm" onclick="closeModal('gc-modal')">Cancel</button>
      <button class="btn-primary" onclick="saveGC()">Save</button>
    </div>
  </div>
</div>

<div class="modal-bg" id="retail-modal">
  <div class="modal">
    <h3 id="retail-modal-title">Retail Contact</h3>
    <div class="form-grid">
      <div class="form-row"><label>Company</label><input id="rm-company"></div>
      <div class="form-row"><label>Contact Name</label><input id="rm-contact"></div>
      <div class="form-row"><label>Email</label><input id="rm-email"></div>
      <div class="form-row"><label>Phone</label><input id="rm-phone"></div>
      <div class="form-row"><label>Role</label><input id="rm-role"></div>
      <div class="form-row"><label>Replied</label><select id="rm-replied"><option>No</option><option>Yes</option></select></div>
    </div>
    <div class="form-row"><label>Notes</label><textarea id="rm-notes"></textarea></div>
    <div class="modal-footer">
      <button class="btn-sm" onclick="closeModal('retail-modal')">Cancel</button>
      <button class="btn-primary" onclick="saveRetail()">Save</button>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://vaubqkmsjsgfqeqbqbvy.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZhdWJxa21zanNnZnFlcWJxYnZ5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY5MDQxNzAsImV4cCI6MjA5MjQ4MDE3MH0.FjZ6oK-6fG_T38oZDGukAVj7cBJsarGh8Stwp14wCZM';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

let currentUser = null;
let currentProfile = null;
let editBidId = null, editGCId = null, editRetailId = null;

const today = new Date(); today.setHours(0,0,0,0);
const todayStr = today.toISOString().split('T')[0];

// AUTH
function switchAuth(mode) {
  document.getElementById('login-form').style.display = mode==='login'?'block':'none';
  document.getElementById('signup-form').style.display = mode==='signup'?'block':'none';
  document.querySelectorAll('.auth-tab-btn').forEach((b,i)=>b.classList.toggle('on',(mode==='login'&&i===0)||(mode==='signup'&&i===1)));
  document.getElementById('auth-err').style.display='none';
}

async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-pass').value;
  const {data,error} = await sb.auth.signInWithPassword({email,password:pass});
  if(error) { showAuthErr(error.message); return; }
  await initApp(data.user);
}

async function doSignup() {
  const name = document.getElementById('signup-name').value.trim();
  const email = document.getElementById('signup-email').value.trim();
  const pass = document.getElementById('signup-pass').value;
  if(!name||!email||!pass) { showAuthErr('Please fill all fields'); return; }
